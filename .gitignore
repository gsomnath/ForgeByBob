# =============================================================================
# CRITICAL: Environment Variables & Secrets - NEVER COMMIT THESE!
# =============================================================================
.env
.env.local
.env.*.local
*.env
!.env.example

# Backup files that might contain secrets
*.env.backup
*.env.bak
*.env.old

